# Auto detect text files and normalize line endings
* text=auto

# Java / Spring files
*.java text
*.xml text
*.yml text
*.yaml text
*.properties text
*.md text
*.gitignore text
*.gitattributes text

# Shell scripts
*.sh text eol=lf
mvnw text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf
mvnw.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary